# --- Secrets: never commit ---
apps/api/.keys/
apps/api/src/main/resources/application-local.yml
apps/api/src/main/resources/application-local.yml.*
!apps/api/src/main/resources/application-local.yml.example
.env
.env.*
!.env.example

# A copy of a secret is still a secret — .bak/.orig/.tmp of an ignored config is not ignored by its rule.
*.bak
*.orig
*.rej
*.tmp

# --- Java / Maven ---
target/
!.mvn/wrapper/maven-wrapper.jar
.mvn/timing.properties

# --- Node ---
node_modules/
dist/
dist-ssr/
*.local
.vite/
coverage/

# --- Editors / OS ---
.idea/
*.iml
.vscode/*
!.vscode/extensions.json
.DS_Store
*.log
